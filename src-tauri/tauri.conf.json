{
  "build": {
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/128x128@2x.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/icon.ico"
    ],
    "targets": "all",
    "resources": {
      "../agents/x86_64-unknown-linux-musl/newt-agent": "agents/x86_64-unknown-linux-musl/newt-agent",
      "../agents/aarch64-unknown-linux-musl/newt-agent": "agents/aarch64-unknown-linux-musl/newt-agent",
      "../agents/aarch64-apple-darwin/newt-agent": "agents/aarch64-apple-darwin/newt-agent",
      "../agents/x86_64-apple-darwin/newt-agent": "agents/x86_64-apple-darwin/newt-agent"
    }
  },
  "productName": "Newt",
  "version": "0.0.0",
  "identifier": "com.newt",
  "plugins": {},
  "app": {
    "withGlobalTauri": false,
    "windows": [],
