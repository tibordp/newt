{
  "build": {
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/128x128@2x.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/icon.ico"
    ],
    "targets": "all"
  },
  "productName": "newt",
  "version": "0.0.0",
  "identifier": "com.newt",
  "plugins": {},
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "newt",
        "width": 800,
        "height": 600,
        "url": "/"
      }
    ],
    "security": {
      "csp": null
    }
  }
}