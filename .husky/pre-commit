npx lint-staged
cargo fmt --all
git diff --name-only -- '*.rs' | if read -r; then
  echo "cargo fmt modified files — please review and re-stage:"
  echo "  $REPLY"
  while read -r f; do echo "  $f"; done
  exit 1
fi
cargo clippy --workspace -- -D warnings

# Regenerate tauri-specta TS bindings; fail if they drift from what's staged.
cargo test -p newt --quiet export_typescript_bindings >/dev/null
git diff --name-only -- src/lib/bindings.ts | if read -r; then
  echo "src/lib/bindings.ts is out of date — please re-stage:"
  echo "  src/lib/bindings.ts"
  exit 1
fi
