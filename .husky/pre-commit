npx lint-staged
cargo fmt --all
git diff --name-only -- '*.rs' | if read -r; then
  echo "cargo fmt modified files — please review and re-stage:"
  echo "  $REPLY"
  while read -r f; do echo "  $f"; done
  exit 1
fi
# `pty-process` and `newt-agent` are Unix-only (POSIX PTY primitives, askpass
# UDS, pkexec, …) and excluded from `default-members` on Windows. Mirror that
# exclusion here so the hook doesn't try to lint them on a Windows host.
case "$OSTYPE" in
  msys*|cygwin*|win32) CLIPPY_EXCLUDES="--exclude pty-process --exclude newt-agent" ;;
  *) CLIPPY_EXCLUDES="" ;;
esac
cargo clippy --workspace $CLIPPY_EXCLUDES -- -D warnings

# Regenerate tauri-specta TS bindings; fail if they drift from what's staged.
cargo test -p newt --quiet export_typescript_bindings >/dev/null
git diff --name-only -- src/lib/bindings.ts | if read -r; then
  echo "src/lib/bindings.ts is out of date — please re-stage:"
  echo "  src/lib/bindings.ts"
  exit 1
fi
